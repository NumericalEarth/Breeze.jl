#!/bin/bash
#SBATCH --job-name=breeze-3d-canyon
#SBATCH --output=/shared/home/greg/Projects/Breeze.jl/validation_output/substepper/terrain_3d_canyon_gpu-%j.log
#SBATCH --time=02:00:00
#SBATCH --nodes=1
#SBATCH --partition=gpu-prod
#SBATCH --gres=gpu:h100:1
#SBATCH --mem=64G

set -eu
echo "=== Node: $(hostname) ==="
nvidia-smi -L
cd /shared/home/greg/Projects/Breeze.jl

export CANYON3D_ARCH=gpu
export CANYON3D_NX=200
export CANYON3D_NY=200
export CANYON3D_NZ=100
export CANYON3D_STOP_SECONDS=3600
export CANYON3D_DT=2.0
export CANYON3D_SNAPSHOT_INTERVAL=60
export CANYON3D_OUTPUT_DIR=validation_output/substepper/terrain_3d_canyon_200x200x100_gpu

julia --project=benchmarking validation_output/substepper/terrain_3d_canyon_validation.jl
